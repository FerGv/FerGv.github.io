---
interface Job {
  title: string;
  company: string;
  url: string;
  initial: string;
  period: string;
  current?: boolean;
  description: string;
  tech: string[];
}

const jobs: Job[] = [
  {
    title: "Desarrollador Web",
    company: "Keyence",
    url: "https://www.keyence.com.mx/",
    initial: "K",
    period: "Ene 2020 — Actual",
    current: true,
    description:
      "Desarrollo y mantenimiento de aplicaciones corporativas internas utilizadas por los distintos departamentos administrativos y de ventas. Implementación de nuevas funcionalidades y colaboración estrecha con cada área para traducir sus requerimientos en soluciones técnicas.",
    tech: [
      "Vue",
      "JavaScript",
      "TypeScript",
      "Node.js",
      "MongoDB",
      "AWS",
      "Docker",
    ],
  },
  {
    title: "Desarrollador Web",
    company: "Klatus",
    url: "https://klatus.com/",
    initial: "K",
    period: "Jul 2018 — Oct 2021",
    description:
      "Diseño y construcción de plataformas web a medida para clientes de distintas industrias. Participación en todo el ciclo de desarrollo: desde la arquitectura hasta el despliegue en producción.",
    tech: ["Python", "Django", "PostgreSQL", "MySQL", "Vue"],
  },
  {
    title: "Desarrollador Web",
    company: "WeeCompany",
    url: "https://www.weecompany.net/",
    initial: "W",
    period: "Mar — Jul 2019",
    description:
      "Mantenimiento y evolución de una plataforma web para el sector salud, conectando aseguradoras con su red de médicos y facilitando la gestión de consultas y coberturas.",
    tech: ["C#", ".NET", "JavaScript"],
  },
  {
    title: "Desarrollador Web",
    company: "Warriors Labs",
    url: "https://warriorslabs.com/",
    initial: "W",
    period: "Ene — Ago 2018",
    description:
      "Desarrollo de un sistema de nómina digital para uso interno de la empresa, con implementación de facturación digital (CFDI) versión 3.3.",
    tech: ["PHP", "Laravel", "MySQL"],
  },
];
---

<section class="py-24" id="experiencia">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-12">
      <span
        class="inline-block text-xs font-semibold tracking-widest uppercase text-nuxt-green mb-3"
      >
        Trayectoria
      </span>
      <h2 class="text-4xl font-bold text-white tracking-tight">
        Experiencia laboral
      </h2>
      <p class="mt-3 text-lg text-nuxt-muted max-w-xl mx-auto">
        Empresas donde he construido soluciones reales de impacto.
      </p>
    </div>

    <ol class="flex flex-col gap-6 max-w-2xl mx-auto" reversed>
      {
        jobs.map((job, i) => (
          <li
            class="grid gap-4 relative"
            style="grid-template-columns: 40px 1fr"
          >
            {/* Timeline line — not on last item */}
            {i < jobs.length - 1 && (
              <div class="timeline-line" aria-hidden="true" />
            )}

            {/* Avatar */}
            <div
              aria-hidden="true"
              class="w-10 h-10 rounded-full bg-white/[0.04] border border-white/10 flex items-center justify-center text-sm font-bold text-nuxt-green shrink-0 z-10"
            >
              {job.initial}
            </div>

            {/* Card */}
            <div class="bg-white/[0.04] border border-white/10 rounded-xl p-5 hover:border-nuxt-green/35 hover:bg-white/[0.07] hover:shadow-[0_0_40px_rgba(0,220,130,0.15)] transition-all">
              <div class="flex items-start justify-between gap-4 flex-wrap">
                <div>
                  <h3 class="text-lg font-semibold text-white leading-snug">
                    {job.title}
                  </h3>
                  <a
                    href={job.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-sm text-nuxt-muted mt-1 hover:text-nuxt-green transition-colors inline-flex items-center gap-1"
                  >
                    {job.company}
                    <svg
                      width="12"
                      height="12"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      aria-hidden="true"
                    >
                      <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6" />
                      <polyline points="15 3 21 3 21 9" />
                      <line x1="10" y1="14" x2="21" y2="3" />
                    </svg>
                  </a>
                </div>
                <span
                  class:list={[
                    "text-xs rounded-full px-3 py-1 whitespace-nowrap shrink-0 border",
                    job.current
                      ? "text-nuxt-green bg-nuxt-green/10 border-nuxt-green/25"
                      : "text-nuxt-muted bg-white/5 border-white/10",
                  ]}
                >
                  {job.period}
                </span>
              </div>

              <p class="mt-3 text-sm text-nuxt-muted leading-relaxed">
                {job.description}
              </p>

              <div class="mt-3 flex flex-wrap gap-2">
                {job.tech.map((t) => (
                  <span class="text-xs px-2 py-0.5 rounded-md bg-white/[0.06] border border-white/10 text-nuxt-muted">
                    {t}
                  </span>
                ))}
              </div>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
