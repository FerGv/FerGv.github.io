---
interface Project {
  title: string;
  description: string;
  url: string;
  svgPath: string;
}

const projects: Project[] = [
  {
    title: "Perfil de GitHub",
    description:
      "Explore el código fuente de mis proyectos personales y open source en GitHub.",
    url: "https://github.com/FerGv",
    svgPath:
      "M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22",
  },
  {
    title: "Blog personal",
    description:
      "Artículos sobre programación, tutoriales y experiencias del mundo del desarrollo.",
    url: "https://blog.fergv.com/",
    svgPath:
      "M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z",
  },
];
---

<section class="py-24 bg-nuxt-soft" id="proyectos">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-12">
      <span
        class="inline-block text-xs font-semibold tracking-widest uppercase text-nuxt-green mb-3"
      >
        Trabajo
      </span>
      <h2 class="text-4xl font-bold text-white tracking-tight">Proyectos</h2>
      <p class="mt-3 text-lg text-nuxt-muted max-w-xl mx-auto">
        Una selección de lo que he construido.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        projects.map((project) => (
          <article class="flex flex-col gap-4 p-6 bg-white/[0.04] border border-white/10 rounded-xl hover:border-nuxt-green/35 hover:bg-white/[0.07] hover:shadow-[0_0_40px_rgba(0,220,130,0.15)] transition-all">
            <div
              aria-hidden="true"
              class="w-12 h-12 rounded-xl bg-nuxt-green/10 border border-nuxt-green/20 flex items-center justify-center text-nuxt-green shrink-0"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path d={project.svgPath} />
              </svg>
            </div>

            <div class="flex-1">
              <h3 class="text-xl font-semibold text-white mb-2">
                {project.title}
              </h3>
              <p class="text-sm text-nuxt-muted leading-relaxed">
                {project.description}
              </p>
            </div>

            <a
              href={project.url}
              class="self-start flex items-center gap-1 text-sm font-medium text-nuxt-green hover:text-[#00f090] transition-colors"
              target="_blank"
              rel="noopener"
            >
              Visitar
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6" />
                <polyline points="15 3 21 3 21 9" />
                <line x1="10" y1="14" x2="21" y2="3" />
              </svg>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
