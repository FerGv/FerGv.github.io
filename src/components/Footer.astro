---

---

<!-- CTA Section -->
<section class="py-32 relative overflow-hidden">
  <div
    class="absolute inset-0 flex items-center justify-center pointer-events-none"
    aria-hidden="true"
  >
    <div
      class="w-[600px] h-[600px] rounded-full"
      style="background: radial-gradient(circle, rgba(0,220,130,0.12) 0%, transparent 70%);"
    >
    </div>
  </div>

  <div class="relative max-w-3xl mx-auto px-6 text-center">
    <span
      class="inline-block text-xs font-semibold tracking-widest uppercase text-nuxt-green mb-3"
    >
      Contacto
    </span>
    <h2
      class="text-4xl md:text-5xl font-bold text-white leading-tight tracking-tight mb-5"
    >
      ¿Tienes un proyecto<br />en mente?
    </h2>
    <p class="text-lg text-nuxt-muted mb-10 max-w-xl mx-auto">
      Estoy disponible para nuevos retos, colaboraciones o simplemente para
      charlar sobre tecnología.
    </p>
    <a
      href="mailto:fergarvil@gmail.com"
      class="inline-flex items-center gap-2 bg-nuxt-green text-nuxt-dark font-semibold px-8 py-4 rounded-full text-base hover:brightness-110 hover:shadow-[0_0_32px_rgba(0,220,130,0.45)] transition-all"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <path
          d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
        ></path>
        <polyline points="22,6 12,13 2,6"></polyline>
      </svg>
      Escríbeme
    </a>
  </div>
</section>

<!-- Footer -->
<footer class="border-t border-white/10 py-10">
  <div
    class="max-w-5xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4"
  >
    <!-- Brand -->
    <div class="flex items-center gap-2">
      <span class="gradient-text font-bold text-lg tracking-tight">fergv</span>
      <span class="text-nuxt-muted text-xs">— Full-Stack Developer</span>
    </div>

    <!-- Copyright -->
    <p class="text-nuxt-muted text-sm order-last sm:order-none">
      Con ♥ por Fernando García &copy; 2026
    </p>

    <!-- Social links -->
    <div class="flex items-center gap-4">
      <a
        href="https://github.com/fergv"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="text-nuxt-muted hover:text-white transition-colors"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 17.07 3.633 16.7 3.633 16.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12"
          ></path>
        </svg>
      </a>
      <a
        href="https://www.linkedin.com/in/jose-fernando-garcia-vazquez/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="text-nuxt-muted hover:text-white transition-colors"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          ></path>
        </svg>
      </a>
    </div>
  </div>
</footer>
