---
const stats = [
  { value: "6+", label: "Años de experiencia" },
  { value: "4", label: "Empresas" },
  { value: "Web", label: "Frontend & Backend" },
];
---

<section
  class="border-y border-white/10 bg-white/[0.02] py-8"
  aria-label="Estadísticas de carrera"
>
  <div
    class="max-w-5xl mx-auto px-6 flex items-center justify-center gap-8 flex-wrap"
  >
    {
      stats.map((stat, i) => (
        <>
          {i > 0 && (
            <div
              aria-hidden="true"
              class="hidden sm:block w-px h-12 bg-white/10 shrink-0"
            />
          )}
          <div class="flex flex-col items-center gap-1 text-center">
            <strong class="text-3xl font-bold tracking-tight gradient-text">
              {stat.value}
            </strong>
            <span class="text-sm text-nuxt-muted">{stat.label}</span>
          </div>
        </>
      ))
    }
  </div>
</section>
